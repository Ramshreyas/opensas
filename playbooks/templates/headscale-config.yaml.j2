# {{ ansible_managed | default('Generated by OpenSAS — headscale.yml') }}
# Headscale configuration for OpenSAS mesh
# Stack: {{ stack_name }} / Domain: {{ stack_domain }}
---
# Server URL: where Tailscale clients connect to this Headscale instance.
# In production, this should be an HTTPS URL with a trusted certificate.
server_url: {{ headscale_server_url }}

# Addresses to listen on
listen_addr: {{ headscale_listen_addr }}
metrics_listen_addr: {{ headscale_metrics_addr }}
grpc_listen_addr: {{ headscale_grpc_listen_addr }}

# TLS (disabled for dev; enable for production with a reverse proxy or built-in)
tls_letsencrypt_hostname: ""
tls_letsencrypt_cache_dir: /var/lib/headscale/cache
tls_cert_path: ""
tls_key_path: ""

# Database — SQLite for small fleets (<50 nodes), Postgres for scale
db_type: sqlite
db_path: {{ headscale_data_dir }}/db.sqlite
db_host: ""
db_port: 0
db_name: ""
db_user: ""
db_pass: ""

# WireGuard / Tailscale IPv4 and IPv6 subnets assigned to nodes
prefixes:
  v4: {{ headscale_prefixes.v4 }}
  v6: {{ headscale_prefixes.v6 }}

# DERP relay map. Defaults to Tailscale's public DERP servers.
# In air-gapped deployments, set up a custom DERP server.
derp:
  server:
    enabled: false
    region_id: 999
  urls:
    - https://controlplane.tailscale.com/derpmap/default
  auto_update_enabled: true
  update_frequency: 24h

# Disable automatic check for updates
disable_check_updates: true

# Ephemeral nodes are deleted on disconnect (not useful for server fleets)
ephemeral_node_inactivity_timeout: 120s

# Node update frequency — how often nodes sync state with control
node_update_check_interval: 10s

# Database debug
db_debug: false

# ACL policy file (empty = allow all)
acl_policy_path: ""

# DNS configuration — use Tailscale's MagicDNS
dns_config:
  override_local_dns: true
  nameservers:
    - 1.1.1.1
    - 9.9.9.9
  domains:
    - {{ stack_domain }}
  magic_dns: true
  base_domain: {{ stack_domain }}

# Logging
log:
  format: text
  level: info

# Unix socket for local CLI access
unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"

# Randomize client IPs on node registration
randomize_client_port: true
